#!/usr/bin/env bash
set -euo pipefail

# vim: set expandtab ts=4 sw=4 ft=bash:

packages_common=(
    age
    bash
    bash-completion@2
    calc
    chezmoi
    clang-format
    cloc
    fzf
    gawk
    git
    git-delta
    gnu-sed
    helm
    htop
    iproute2mac
    jq
    k9s
    kind
    kubernetes-cli
    lima
    nmap
    node
    pidof
    podman
    podman-compose
    readline
    ripgrep
    shellcheck
    tmux
    tree
    vim
    watch
    wget
    yazi
    yq
)

packages_machine=(
    {{- if .personalMachine }}
    gitleaks
    pre-commit
    teamookla/speedtest/speedtest
    {{- else }}
    awscli
    azure-cli
    cloud-nuke
    clusterctl
    coreutils
    gh
    goreleaser
    govc
    graphviz
    jwt-cli
    lima-additional-guestagents
    minio-mc
    openstackclient
    qemu
    sshuttle
    velero
    {{- end }}
)

if [[ "${1:-}" == "--list" ]]; then
    # List mode is used by brew-sync-report to read tracked packages without installing.
    printf '%s\n' "${packages_common[@]}" "${packages_machine[@]}"
    exit 0
fi

brew install "${packages_common[@]}"
brew install "${packages_machine[@]}"
