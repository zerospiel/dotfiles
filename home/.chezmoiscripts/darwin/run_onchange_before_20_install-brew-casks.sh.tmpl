#!/usr/bin/env bash
set -euo pipefail

# vim: set expandtab ts=4 sw=4 ft=bash:

casks_common=(
    appcleaner
    ghostty
    google-chrome
    logi-options+
    podman-desktop
    spotify
)

casks_machine=(
    {{- if .personalMachine }}
    discord
    dropbox
    microsoft-auto-update
    microsoft-onenote
    microsoft-teams
    onedrive
    transmission
    vlc
    zoom
    {{- else }}
    bitwarden
    lens
    telegram
    {{- end }}
)

if [[ "${1:-}" == "--list" ]]; then
    # List mode is used by brew-sync-report to read tracked casks without installing.
    printf '%s\n' "${casks_common[@]}" "${casks_machine[@]}"
    exit 0
fi

brew install --cask "${casks_common[@]}"
brew install --cask "${casks_machine[@]}"
